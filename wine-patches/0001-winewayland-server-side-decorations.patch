+/***********************************************************************
+ *              get_mwm_decoration_for_style
+ */
+static BOOL get_mwm_decoration_for_style( DWORD style, DWORD ex_style )
+{
+    if (ex_style & WS_EX_TOOLWINDOW) return FALSE;
+    if (ex_style & WS_EX_LAYERED) return FALSE;
+
+    if ((style & WS_CAPTION) == WS_CAPTION)
+    {
+        return TRUE;
+    }
+    return FALSE;
+}
+
+/***********************************************************************
+ *              get_mwm_decoration
+ *    get window should have decoration
+ */
+static BOOL get_mwm_decoration( struct wayland_win_data *data )
+{
+    DWORD style, ex_style;
+
+    if (data->hwnd == NtUserGetDesktopWindow())
+    {
+        /* force some styles for the desktop to get the correct decorations */
+        style = WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX;
+        ex_style = WS_EX_APPWINDOW;
+    }
+    else
+    {
+        style = NtUserGetWindowLongW( data->hwnd, GWL_STYLE );
+        ex_style = NtUserGetWindowLongW( data->hwnd, GWL_EXSTYLE );
+    }
+
+    if (EqualRect( &data->rects.window, &data->rects.visible ))
+    {
+        return FALSE;
+    }
+    return get_mwm_decoration_for_style( style, ex_style );
+}
