                             hwnd, toplevel,
                             wl_proxy_get_id((struct wl_proxy *)vs->wl_subsurface),
-                            data->rects.window.left, data->rects.window.top,
+                            (long)data->rects.window.left, (long)data->rects.window.top,
                             w, h);
