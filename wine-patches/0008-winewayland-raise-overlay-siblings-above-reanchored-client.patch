--- a/dlls/winewayland.drv/wayland_surface.c
+++ b/dlls/winewayland.drv/wayland_surface.c
@@ -1446,6 +1446,8 @@
         /* Real toplevel change - must move the subsurface to a new parent.
          * Destroy old one (different parent), create fresh. Don't recurse
          * into attach(NULL) - that path now soft-hides only. */
+        TRACE("[fusion-box patch 0008] client (re)anchor hwnd=%p old_toplevel=%p new_toplevel=%p\n",
+              hwnd, client->toplevel, toplevel);
         if (client->wl_subsurface)
         {
             wl_subsurface_destroy(client->wl_subsurface);
@@ -1465,6 +1467,12 @@
         wl_subsurface_set_desync(client->wl_subsurface);

         client->toplevel = toplevel;
+
+        /* fusion-box patch 0008: the new wl_subsurface lands at TOP of the
+         * substack per Wayland spec, burying any pre-existing sibling
+         * overlay subsurfaces (patch 0006 vsubs, Browser, Comments, etc).
+         * Walk wayland_win_data tree and raise each one back above us. */
+        raise_overlay_siblings_above_client(client->wl_surface, toplevel);
     }
