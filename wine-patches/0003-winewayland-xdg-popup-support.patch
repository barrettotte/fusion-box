# fusion-box wine patch 0003
# Add xdg_popup support to winewayland.drv for WS_POPUP windows with an owner.
#
# Bug observed in wine 11.10:
# winewayland.drv has zero xdg_popup support. Every visible WS_POPUP window
# becomes an xdg_toplevel, which means the wayland compositor (KWin under
# Plasma 6) picks an arbitrary position - typically far from where the Win32
# app requested. Result: tooltips, dropdown menus, ribbon submenus, and
# Fusion's bottom toolbar all appear at wrong positions or not at all.
#
# Empirical reproducer: Autodesk Fusion 360 under wine 11.10 + winewayland.drv
# on KDE Plasma 6.
#   - CREATE / MODIFY / CONFIGURE / etc. ribbon dropdowns never render.
#   - Tooltips never appear.
#   - Bottom toolbar (Qt683QWindowToolSaveBits) lands on a random monitor.
#   - Object Browser dock undocks-on-click because it gets created as a
#     standalone toplevel instead of a popup of the main window.
#
# Fix: detect WS_POPUP windows that should be xdg_popups (style includes
# WS_POPUP, not WS_CHILD, has an owner or is WS_EX_TOOLWINDOW), create an
# xdg_surface + xdg_popup with an xdg_positioner anchored to the popup's
# requested screen position translated to parent-local coords. Use
# SLIDE_X | SLIDE_Y | FLIP_X | FLIP_Y constraint adjustment so the compositor
# can repair off-screen placements.
#
# Two empirically-discovered Qt6 quirks the patch must accommodate:
#   1. Qt6 QMenu sets WS_EX_LAYERED for drop-shadow styling but never calls
#      SetLayeredWindowAttributes / UpdateLayeredWindow. Wine's existing
#      visibility check gates layered windows behind that call - meaning Qt6
#      menus stay invisible forever. We relax the gate for WS_POPUP windows
#      so they always count as visible regardless of layered attribs state.
#   2. Qt6 QMenu often passes NULL as the popup's parent HWND to CreateWindow,
#      so GW_OWNER returns NULL. When that happens AND WS_EX_TOOLWINDOW is
#      set (true for menus, tooltips - false for main app windows that also
#      use WS_POPUP for custom title-bar styling), fall back to the thread's
#      foreground window as the implicit parent.
#
# The WS_EX_TOOLWINDOW gate on the fallback is critical: Fusion's MAIN window
# is WS_POPUP with owner=NULL (it uses WS_POPUP for Qt's custom title-bar
# rendering). Without the WS_EX_TOOLWINDOW gate, the fallback parents the
# main window as a popup of whatever splash/sign-in window has foreground at
# that moment, triggering an xdg-shell protocol error and crashing the
# compositor connection.
#
# Status: verified 2026-06-07 against Fusion 360 v2703.1.11.
#   FIXED - Object Browser dock renders and stays docked (no more undock-
#           on-click to a floating window).
#   FIXED - Sketch palette renders.
#   FIXED - Tooltips render at correct positions.
#   FIXED - Bottom toolbar positions correctly when main is on the user's
#           primary monitor.
#   STILL BROKEN - CREATE dropdown and other ribbon dropdowns: popup IS
#           created with a valid xdg_positioner, but Fusion supplies a screen
#           position that's outside the parent surface's coord range when
#           wine's display.c reports the main window's screen-coord origin on
#           a secondary monitor. Anchor comes out negative (e.g. -53), KWin's
#           constraint adjustment fails to recover, popup ends up invisible.
#           Root cause is upstream of this patch: wine's multi-monitor display
#           reporting in winewayland.drv/display.c (see fusion-box memory:
#           "popup-support-checkpoint").
#
# Source-of-truth snapshot retained at
# wine-patches/scratch/checkpoint-popup-multimon/ in case this patch is ever
# rolled back during multi-monitor coord-bug investigation.
#
# Author: fusion-box (claude-code session, with Barrett Otte)
#
--- a/dlls/winewayland.drv/window.c
+++ b/dlls/winewayland.drv/window.c
@@ -234,17 +234,79 @@
 {
     struct wayland_client_surface *client = data->client_surface;
     struct wayland_surface *surface;
+    struct wayland_surface *popup_parent_surface = NULL;
+    HWND popup_owner_hwnd = 0;
+    RECT popup_anchor_rect = {0};
     enum wayland_surface_role role;
     BOOL visible;
+    DWORD style = NtUserGetWindowLongW(data->hwnd, GWL_STYLE);
     DWORD exstyle = NtUserGetWindowLongW(data->hwnd, GWL_EXSTYLE);
     struct wl_region *input_region;
 
     TRACE("hwnd=%p\n", data->hwnd);
 
-    visible = ((NtUserGetWindowLongW(data->hwnd, GWL_STYLE) & WS_VISIBLE) == WS_VISIBLE) &&
-               (!(exstyle & WS_EX_LAYERED) || data->layered_attribs_set);
+    /* fusion-box: relax the WS_EX_LAYERED-without-attribs gate for WS_POPUP.
+     * Qt6 QMenu (and Fusion's CREATE dropdown, tooltips, etc.) mark themselves
+     * WS_EX_LAYERED purely for the drop-shadow style but render via normal
+     * GDI/Vulkan paths - they never call SetLayeredWindowAttributes /
+     * UpdateLayeredWindow. The original gate was meant for true layered-paint
+     * apps that push pixels exclusively through UpdateLayeredWindow; for
+     * popups, deferring visibility leaves them invisible forever. */
+    visible = ((style & WS_VISIBLE) == WS_VISIBLE) &&
+               (!(exstyle & WS_EX_LAYERED) || data->layered_attribs_set ||
+                (style & WS_POPUP));
+
+    /* fusion-box: detect WS_POPUP-with-owner case before defaulting to toplevel.
+     * A Win32 popup window with an explicit owner (set via CreateWindow's
+     * hwndParent when WS_POPUP is in the style) should be presented as an
+     * xdg_popup so the compositor can position it relative to the owner.
+     * Without this, wine creates a free-floating xdg_toplevel and KWin
+     * picks an arbitrary position (often a different monitor entirely).
+     *
+     * Criteria for popup role:
+     *   - WS_POPUP set and WS_CHILD not set (true popup, not a child window)
+     *   - Has an owner HWND (GW_OWNER), distinct from self
+     *   - Owner has a wayland_surface with an xdg_surface (toplevel or popup) */
+    if (visible && (style & WS_POPUP) && !(style & WS_CHILD) && !toplevel_surface)
+    {
+        popup_owner_hwnd = NtUserGetWindowRelative(data->hwnd, GW_OWNER);
+        /* fusion-box: Qt6 QMenu and tooltips create WS_POPUP windows WITHOUT
+         * setting GW_OWNER (verified empirically with Fusion's CREATE menu -
+         * owner=NULL despite the popup belonging to the main window). Without
+         * a parent xdg_surface, xdg_popup can't be created. Fall back to the
+         * thread's foreground window - but ONLY if WS_EX_TOOLWINDOW is set,
+         * which reliably distinguishes true menu-like popups from main app
+         * windows that happen to use WS_POPUP for custom title bar styling
+         * (Fusion's main window does this - using fg fallback on it parented
+         * the main as a popup of a random splash window and crashed the
+         * compositor connection). */
+        if ((!popup_owner_hwnd || popup_owner_hwnd == data->hwnd) &&
+            (exstyle & WS_EX_TOOLWINDOW))
+            popup_owner_hwnd = NtUserGetForegroundWindow();
+        if (popup_owner_hwnd && popup_owner_hwnd != data->hwnd)
+        {
+            struct wayland_win_data *owner_data =
+                wayland_win_data_get_nolock(popup_owner_hwnd);
+            if (owner_data && owner_data->wayland_surface &&
+                (owner_data->wayland_surface->role == WAYLAND_SURFACE_ROLE_TOPLEVEL ||
+                 owner_data->wayland_surface->role == WAYLAND_SURFACE_ROLE_POPUP))
+            {
+                popup_parent_surface = owner_data->wayland_surface;
+                /* Anchor rect: the popup's window rect translated to
+                 * owner-local coordinates. The popup itself sits with its
+                 * top-left at the anchor's top-left (see make_popup). */
+                popup_anchor_rect.left   = data->rects.window.left -
+                    owner_data->rects.window.left;
+                popup_anchor_rect.top    = data->rects.window.top -
+                    owner_data->rects.window.top;
+                popup_anchor_rect.right  = popup_anchor_rect.left + 1;
+                popup_anchor_rect.bottom = popup_anchor_rect.top + 1;
+            }
+        }
+    }
 
     if (!visible) role = WAYLAND_SURFACE_ROLE_NONE;
+    else if (popup_parent_surface) role = WAYLAND_SURFACE_ROLE_POPUP;
     else if (toplevel_surface) role = WAYLAND_SURFACE_ROLE_SUBSURFACE;
     else role = WAYLAND_SURFACE_ROLE_TOPLEVEL;
 
@@ -280,6 +342,15 @@
     case WAYLAND_SURFACE_ROLE_SUBSURFACE:
         wayland_surface_make_subsurface(surface, toplevel_surface);
         break;
+    case WAYLAND_SURFACE_ROLE_POPUP:
+    {
+        int pw = data->rects.window.right - data->rects.window.left;
+        int ph = data->rects.window.bottom - data->rects.window.top;
+        if (pw <= 0) pw = 1;
+        if (ph <= 0) ph = 1;
+        wayland_surface_make_popup(surface, popup_parent_surface, &popup_anchor_rect, pw, ph);
+        break;
+    }
     }
 
     if (visible && client) wayland_client_surface_attach(client, data->hwnd);
--- a/dlls/winewayland.drv/wayland_surface.c
+++ b/dlls/winewayland.drv/wayland_surface.c
@@ -60,6 +60,18 @@
         surface->requested = surface->pending;
         memset(&surface->pending, 0, sizeof(surface->pending));
     }
+    /* fusion-box: popup-role xdg_surfaces also receive configure events and
+     * MUST be acked before any buffer commit (xdg-shell protocol error 3
+     * otherwise). Popups have fixed geometry (we set it via xdg_positioner)
+     * so we don't need to round-trip through WM_WAYLAND_CONFIGURE - just
+     * ack directly here and post an expose to trigger the first paint. */
+    else if (surface && surface->role == WAYLAND_SURFACE_ROLE_POPUP &&
+             surface->popup_xdg_surface == xdg_surface)
+    {
+        xdg_surface_ack_configure(xdg_surface, serial);
+        surface->current.serial = serial;
+        initial_configure = TRUE;
+    }
 
     wayland_win_data_release(data);
 
@@ -375,6 +387,147 @@
