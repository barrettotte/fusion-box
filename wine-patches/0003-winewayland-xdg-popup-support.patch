 /**********************************************************************
+ *          fusion-box: xdg_popup listener + wayland_surface_make_popup
+ *
+ * Wine has historically created xdg_toplevel for every Win32 popup window
+ * (WS_POPUP without WS_CHILD). xdg_toplevel has no client-side positioning
+ * hint - the compositor decides where to place it. For popup menus,
+ * tooltips, and floating toolbars that need to anchor near their owning
+ * widget, this produces visibly wrong placement (popup on a different
+ * monitor, dropdown halfway across the screen, etc.). Per the xdg-shell
+ * spec, popups should use xdg_popup with an xdg_positioner describing the
+ * anchor rectangle on the parent and the desired gravity. This is what
+ * makes "click button -> menu appears below button" actually work.
+ *
+ * Reproducer: `wine-tests/overlap-test.c` Test 3.
+ */
+static void xdg_popup_handle_configure(void *data, struct xdg_popup *xdg_popup,
+                                       int32_t x, int32_t y,
+                                       int32_t width, int32_t height)
+{
+    TRACE("hwnd=%p x=%d y=%d w=%d h=%d\n", (HWND)data, x, y, width, height);
+    /* Compositor confirms popup position. We don't currently resize/relocate
+     * the Win32 window in response - Fusion-style popups have fixed geometry. */
+}
+
+static void xdg_popup_handle_popup_done(void *data, struct xdg_popup *xdg_popup)
+{
+    HWND hwnd = (HWND)data;
+    TRACE("hwnd=%p - compositor dismissed popup\n", hwnd);
+    /* Compositor closed the popup (e.g. user clicked outside). Tell Win32 to
+     * destroy or hide the corresponding window so the app's state stays in
+     * sync. Use a posted close so we don't tear down the popup from inside
+     * the wayland event callback. */
+    NtUserPostMessage(hwnd, WM_CLOSE, 0, 0);
+}
+
+static void xdg_popup_handle_repositioned(void *data, struct xdg_popup *xdg_popup,
+                                          uint32_t token)
+{
+    TRACE("hwnd=%p token=%u\n", (HWND)data, token);
+}
+
+static const struct xdg_popup_listener xdg_popup_listener =
+{
+    xdg_popup_handle_configure,
+    xdg_popup_handle_popup_done,
+    xdg_popup_handle_repositioned,
+};
+
+int wayland_surface_make_popup(struct wayland_surface *surface,
+                               struct wayland_surface *parent_surface,
+                               const RECT *anchor_rect, int width, int height)
+{
+    struct xdg_positioner *positioner = NULL;
+    struct xdg_surface *parent_xdg = NULL;
+    int aw, ah;
+
+    if (!surface || !parent_surface || !anchor_rect) return -1;
+    if (width <= 0) width = 1;
+    if (height <= 0) height = 1;
+
+    /* Parent must have an xdg_surface (either toplevel or popup itself). */
+    if (parent_surface->role == WAYLAND_SURFACE_ROLE_TOPLEVEL)
+        parent_xdg = parent_surface->xdg_surface;
+    else if (parent_surface->role == WAYLAND_SURFACE_ROLE_POPUP)
+        parent_xdg = parent_surface->popup_xdg_surface;
+    if (!parent_xdg)
+    {
+        ERR("[fusion-box-popup] parent surface=%p has no xdg_surface (role=%d)\n",
+            parent_surface, parent_surface->role);
+        return -1;
+    }
+
+    assert(!surface->role || surface->role == WAYLAND_SURFACE_ROLE_POPUP);
+    if (surface->xdg_popup && surface->popup_parent_hwnd == parent_surface->hwnd)
+        return 0; /* already configured for this parent */
+
+    wayland_surface_clear_role(surface);
+    surface->role = WAYLAND_SURFACE_ROLE_POPUP;
+
+    surface->popup_xdg_surface =
+        xdg_wm_base_get_xdg_surface(process_wayland.xdg_wm_base, surface->wl_surface);
+    if (!surface->popup_xdg_surface) goto err;
+    xdg_surface_add_listener(surface->popup_xdg_surface, &xdg_surface_listener, surface->hwnd);
+
+    positioner = xdg_wm_base_create_positioner(process_wayland.xdg_wm_base);
+    if (!positioner) goto err;
+
+    aw = anchor_rect->right - anchor_rect->left;
+    ah = anchor_rect->bottom - anchor_rect->top;
+    if (aw <= 0) aw = 1;
+    if (ah <= 0) ah = 1;
+
+    xdg_positioner_set_size(positioner, width, height);
+    xdg_positioner_set_anchor_rect(positioner, anchor_rect->left, anchor_rect->top, aw, ah);
+    /* Anchor at top-left of anchor_rect -> popup's top-left aligns there. */
+    xdg_positioner_set_anchor(positioner, XDG_POSITIONER_ANCHOR_TOP_LEFT);
+    xdg_positioner_set_gravity(positioner, XDG_POSITIONER_GRAVITY_BOTTOM_RIGHT);
+    /* Allow compositor to slide/resize if the popup doesn't fit on screen.
+     * (Optional but recommended by spec.) */
+    xdg_positioner_set_constraint_adjustment(positioner,
+        XDG_POSITIONER_CONSTRAINT_ADJUSTMENT_SLIDE_X |
+        XDG_POSITIONER_CONSTRAINT_ADJUSTMENT_SLIDE_Y |
+        XDG_POSITIONER_CONSTRAINT_ADJUSTMENT_FLIP_X  |
+        XDG_POSITIONER_CONSTRAINT_ADJUSTMENT_FLIP_Y);
+
+    surface->xdg_popup = xdg_surface_get_popup(surface->popup_xdg_surface, parent_xdg, positioner);
+    xdg_positioner_destroy(positioner);
+    positioner = NULL;
+    if (!surface->xdg_popup) goto err;
+    xdg_popup_add_listener(surface->xdg_popup, &xdg_popup_listener, surface->hwnd);
+
+    surface->popup_parent_hwnd = parent_surface->hwnd;
+
+    TRACE("[fusion-box-popup] popup_hwnd=%p parent_hwnd=%p anchor=(%ld,%ld,%ld,%ld) size=%dx%d\n",
+        surface->hwnd, parent_surface->hwnd,
+        anchor_rect->left, anchor_rect->top, anchor_rect->right, anchor_rect->bottom,
+        width, height);
+
+    /* Per xdg-shell spec, the client MUST do an empty wl_surface_commit
+     * AFTER assigning the xdg_popup role - that's the signal to the
+     * compositor that the role is set up and it can send the initial
+     * xdg_surface.configure event. Explicitly attach NULL first to be
+     * defensive against any buffer that might have been attached between
+     * clear_role and now (some wine code paths can race). After the
+     * compositor's configure comes back, xdg_surface_handle_configure acks
+     * and sets surface->current.serial; until then,
+     * wayland_surface_reconfigure (POPUP case) returns FALSE so the GDI
+     * window_surface flush won't commit a buffer too early. */
+    wl_surface_attach(surface->wl_surface, NULL, 0, 0);
+    wl_surface_commit(surface->wl_surface);
+    wl_display_flush(process_wayland.wl_display);
+
+    return 0;
+
+err:
+    if (positioner) xdg_positioner_destroy(positioner);
+    wayland_surface_clear_role(surface);
+    ERR("[fusion-box-popup] Failed to assign popup role to wayland surface\n");
+    return -1;
+}
+
