+     * (wayland surfaces retain their last attached buffer until re-attached),
+     * so the toolbar stays visible at the last stable position. Only meaningful
+     * on wayland_win_data entries whose wayland_surface has TOPLEVEL role. */
+    RECT last_toplevel_screen_rect;
+    int  toplevel_stable_count;
 };
 
