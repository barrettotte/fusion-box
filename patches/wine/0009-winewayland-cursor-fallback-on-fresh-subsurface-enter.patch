# fusion-box wine patch 0009
# Stop calling wl_pointer.set_cursor with a NULL surface from pointer.enter
# when the entered hwnd has no cached cursor - either inherit the last
# successfully-applied cursor, or (on the very first enter of the session)
# skip the wire call entirely.
#
# Bug - visible cursor flicker / "hover-race" on first hover after some
# Fusion startups (~50% of launches reported as triggering it). Symptom: the
# first time you hover any tooltip-bearing UI element (ribbon button, sketch
# plane, etc.), the cursor briefly disappears then reappears, and Qt's hover
# state (tooltip timer, sketch hover-target) gets dropped. Repeats while
# the pointer crosses between two overlapping wl_subsurfaces.
#
# Diagnosis (2026-06-12 +waylanddrv,+cursor,+win,WAYLAND_DEBUG=1 capture,
# good vs bad startup comparison):
#
#   Counters         | good baseline | bad case
#   -----------------+---------------+----------
#   set_cursor wire  |       1       |    4
#   set_shape calls  |      10       |   19
#   pointer.enter    |       4       |    9
#   WAYLAND_SetCursor|      11       |   16
#
# The mechanism is the SAME in both states - bad just triggers it more often.
# Mechanism:
#   1. KWin fires wl_pointer.leave(old_surface) + wl_pointer.enter(new_surface)
#      every time the cursor crosses a wl_subsurface boundary - including
#      child subsurfaces of main inside Fusion's own window.
#   2. wine's pointer_handle_enter (wayland_pointer.c:206) calls
#      `wayland_set_cursor(hwnd, NULL, FALSE)` - i.e., "use whatever cursor
#      we have cached for this hwnd, none explicit."
#   3. wayland_set_cursor reads `data->hcursor` (patch 0007's per-hwnd
#      cursor storage on wayland_win_data). If the entered hwnd is a fresh
#      subsurface that Win32 hasn't called SetCursor on yet, data->hcursor
#      is NULL.
#   4. With hcursor=NULL, the function falls into the "clear cursor" path:
#      wayland_pointer_update_cursor_buffer(NULL) -> goto clear_cursor ->
#      shm_buffer is unref'd, then wayland_pointer_update_cursor_surface
#      sees cursor->wl_surface = NULL, and we send
#      wl_pointer.set_cursor(serial, nil, 0, 0) - which HIDES the cursor.
#   5. Win32 SetCursor fires moments later (~5-20ms) - WAYLAND_SetCursor
#      runs with hcursor=0x4007a (Qt's arrow); cursor reappears.
#
# Steps 4->5 is the visible flicker. Each pointer.enter on a fresh subsurface
# causes one cursor blink. The "bad startup" case is bad because something
# in Qt's layout makes the cursor ping-pong between main (wl_surface#81)
# and one of its child subsurfaces (wl_surface#283) repeatedly, so the user
# sees several blinks in rapid succession, and every blink resets the Win32
# hover tracker - cancelling tooltips, dropping sketch-plane hover targets,
# etc.
#
# Trace evidence (bad case, around line 78437 of
# debug/captures/hover-race-20260612-181413.log):
#     [3482272.813] wl_pointer#30.leave(12977, wl_surface#81)
#     [3482272.821] wl_pointer#30.enter(12977, wl_surface#283, 222.43, 0.79)
#     [3482272.830] -> wl_pointer#30.set_cursor(12977, nil, 0, 0)     <- HIDE
#     [3482272.834] -> wp_cursor_shape_device_v1#46.destroy()
#     ...12ms later, Win32 wakes up:
#     [WAYLAND_SetCursor hwnd=0x3c0134 hcursor=0x4007a]
#     [3482272.971] -> wp_cursor_shape_manager_v1#12.get_pointer(new id ...)
#     [3482272.976] -> wp_cursor_shape_device_v1#418.set_shape(12977, 1) <- RESHOW
#
# Fix - two complementary mechanisms in wayland_set_cursor:
#
#   1. Add `HCURSOR last_hcursor` to struct wayland_pointer (waylanddrv.h),
#      track the cursor most recently pushed to the compositor.
#   2. On pointer_handle_enter -> wayland_set_cursor(hwnd, NULL, FALSE)
#      (i.e., use_hcursor=FALSE, "use cached"), if data->hcursor turns out
#      to be NULL but pointer->last_hcursor is set, use last_hcursor instead
#      of the NULL hide-cursor path. Preserves continuity across subsurface
#      boundary crossings.
#   3. If BOTH data->hcursor AND pointer->last_hcursor are NULL (true on the
#      very first pointer.enter of the session), skip the wire call entirely.
#      Per Wayland spec, "the cursor image is undefined" after enter just
#      lets the compositor display whatever it wants - KWin keeps showing
#      the previous cursor, which is what the user expects. Better than
#      actively hiding.
#   4. Both fixes are gated on the original `use_hcursor==FALSE` state, so
#      explicit WAYLAND_SetCursor(hwnd, NULL, TRUE) from Win32 (Qt wanting
#      to hide the cursor, e.g., during window destroy) is still honored.
#
# Validation (2026-06-12 second capture iteration with patch v1 - only
# items 1 and 2 in place, no skip-on-first-enter):
#   v1 reduced bad-state counters but missed the first-enter case:
#     set_cursor(nil) wire calls: 4 -> 2 (one was first-enter, one was Win32 NULL)
#     set_shape: 19 -> 11
#     pointer.enter: 9 -> 5
#     wp_cursor_shape_device destroy: 2 -> 0
#   User still saw flicker on first-enter. Item 3 (skip on no-cache-no-last)
#   was added to handle the first-enter case.
#
# Doesn't fix the secondary mechanism (why bad startups make the pointer
# ping-pong at all - probably a Qt subsurface layout in bad state placing
# two overlapping child windows under the cursor). But the visible damage
# from the ping-pong is the cursor flicker, which this patch eliminates.
#
# Status: drafted 2026-06-12, v1 partially landed (counter reductions
# verified), v2 (with skip-on-first-enter) staged.
#
# Apply from the wine source root: `patch -p1 < this-file`. Depends on
# patches 0001-0008 (line offsets assume all are applied).
#
# Author: fusion-box (claude-code session, with Barrett Otte)
#

--- a/dlls/winewayland.drv/waylanddrv.h	2026-07-03 19:50:09.594601594 -0400
+++ b/dlls/winewayland.drv/waylanddrv.h	2026-07-03 20:02:31.656639877 -0400
@@ -118,6 +118,10 @@
     uint32_t enter_serial;
     uint32_t button_serial;
     struct wayland_cursor cursor;
+    /* fusion-box: last-applied cursor, fallback for fresh subsurfaces with
+     * data->hcursor == NULL. Prevents cursor flicker on boundary cross.
+     * See patch 0009. */
+    HCURSOR last_hcursor;
     double accum_x;
     double accum_y;
     pthread_mutex_t mutex;
--- a/dlls/winewayland.drv/wayland_pointer.c	2026-07-03 19:49:43.339046697 -0400
+++ b/dlls/winewayland.drv/wayland_pointer.c	2026-07-03 20:03:02.930641490 -0400
@@ -760,6 +760,9 @@
     struct wayland_win_data *data;
     double scale;
     BOOL reapply_clip = FALSE;
+    /* fusion-box: fallback allowed only when caller passed no explicit
+     * cursor — WAYLAND_SetCursor(NULL) intentionally hides. See patch 0009. */
+    BOOL fallback_to_last_hcursor = !use_hcursor;
 
     if ((data = wayland_win_data_get(hwnd)))
     {
@@ -780,6 +783,21 @@
     }
 
     pthread_mutex_lock(&pointer->mutex);
+
+    /* fusion-box: on fresh-subsurface enter with no cached cursor, borrow
+     * the last one we showed — kills the subsurface-boundary flicker.
+     * See patch 0009 header. */
+    if (fallback_to_last_hcursor && !hcursor && pointer->last_hcursor)
+        hcursor = pointer->last_hcursor;
+
+    /* fusion-box: first enter of the session, no cursor known — skip the
+     * wire call rather than setting NULL (which would hide). See patch 0009. */
+    if (fallback_to_last_hcursor && !hcursor)
+    {
+        pthread_mutex_unlock(&pointer->mutex);
+        return;
+    }
+
     if (pointer->focused_hwnd == hwnd)
     {
         if ((!use_hcursor && pointer->wp_cursor_shape_device_v1) ||
@@ -800,6 +818,9 @@
         }
         wl_display_flush(process_wayland.wl_display);
         reapply_clip = TRUE;
+
+        /* fusion-box: cache for next fresh-subsurface enter fallback. */
+        if (hcursor) pointer->last_hcursor = hcursor;
     }
     pthread_mutex_unlock(&pointer->mutex);
 
