 /***********************************************************************
+ *           WAYLAND_ShouldPromoteChildSurface
+ *
+ * fusion-box (patch 0012): tells wine core (via patch 0011's driver-interface
+ * hook) that a specific WS_CHILD HWND should get its own wayland-backed
+ * window_surface — i.e., its own shm_buffer, damage tracking, and set_window_surface_contents
+ * flush hook — even though it's a child. This is required for patch 0006's
+ * virtual subsurface refactor: attaching the CHILD's OWN shm_buffer to the
+ * vsub means Fusion's layout changes (Data Panel open, secondary monitor,
+ * anything that disrupts child→toplevel DIB merging) can no longer starve
+ * the vsub of correct pixels.
+ *
+ * Eligibility MUST be checked here independently — pShouldPromoteChildSurface
+ * fires from wine's get_window_surface during pWindowPosChanging, which is
+ * BEFORE our WAYLAND_WindowPosChanged decide function has had a chance to set
+ * data->virtual_buffer. We replicate the same size/style/parent gating rather
+ * than querying that flag.
+ *
+ * Default (nulldrv): FALSE. Preserves legacy WS_CHILD painting for every
+ * other driver and every other widget.
+ */
+BOOL WAYLAND_ShouldPromoteChildSurface(HWND hwnd)
+{
+    struct wayland_win_data *tdata, *cdata;
+    UINT style;
+    RECT rect;
+    HWND toplevel;
+    int w, h;
+    BOOL eligible = FALSE;
+    const char *reject = NULL;
+
+    style = NtUserGetWindowLongW(hwnd, GWL_STYLE);
+    /* NB: intentionally NOT gating on WS_VISIBLE. Wine's caller
+     * (get_window_surface in win32u/window.c) invokes this from
+     * WindowPosChanging, before the style has been updated to reflect the
+     * incoming SetWindowPos change. If SWP_SHOWWINDOW is set on the call,
+     * wine's own else-if chain sets needs_surface=TRUE after ours returns —
+     * but only if we return TRUE here first. Gating on WS_VISIBLE would
+     * make us return FALSE on the exact SHOWWINDOW call that promotes the
+     * child. */
+    if (!(style & WS_CHILD)) reject = "no WS_CHILD";
+
+    if (!reject && !NtUserGetWindowRect(hwnd, &rect, 0)) reject = "GetWindowRect failed";
+    if (!reject)
+    {
+        w = rect.right - rect.left;
+        h = rect.bottom - rect.top;
+        if (w <= 0 || h <= 0 || w > 1000 || h > 50)
+            reject = "size out of toolbar gate";
+    }
+
+    if (!reject)
+    {
+        toplevel = NtUserGetAncestor(hwnd, GA_ROOT);
+        if (!toplevel || toplevel == hwnd) reject = "no toplevel ancestor";
+    }
+
+    if (!reject)
+    {
+        if (!(tdata = wayland_win_data_get(toplevel))) reject = "toplevel has no wayland_win_data";
+        else
+        {
+            if (!tdata->wayland_surface) reject = "toplevel wayland_surface=NULL";
+            else if (tdata->wayland_surface->role != WAYLAND_SURFACE_ROLE_TOPLEVEL) reject = "toplevel wrong role";
+            /* NB: no check on tdata->client_surface here. Patch 0006 does not
+             * gate on that either — the toplevel occasionally holds a
+             * client_surface pointer during transient states, and rejecting
+             * here would skip promotion of otherwise-eligible children. */
+            else if ((cdata = wayland_win_data_get(hwnd)))
+            {
+                if (cdata->client_surface) reject = "child has client_surface";
+                else eligible = TRUE;
+                wayland_win_data_release(cdata);
+            }
+            else reject = "child has no wayland_win_data";
+            wayland_win_data_release(tdata);
+        }
+    }
+
+    if (eligible)
+        TRACE("[fusion-box-vsub] promote hwnd=%p (style=%#x size=%dx%d)\n", hwnd, style, w, h);
+    else
+        TRACE("[fusion-box-vsub] no-promote hwnd=%p style=%#x: %s\n", hwnd, style, reject ? reject : "unknown");
+
+    return eligible;
+}
+
